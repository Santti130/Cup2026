{
    "rewrites": [
        { "source": "/calendario", "destination": "/src/pages/calendario.html" }
    ],
    "headers": [
        {
            "source": "/sitemap.xml",
            "headers": [
                { "key": "Content-Type", "value": "application/xml" }
            ]
        }
    ],
    "buildCommand": "npm run build",
    "outputDirectory": "dist"
}